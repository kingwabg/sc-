// schema.prisma — Office portal Supabase / Postgres schema
//
// 참고: schema는 Postgres-native (Supabase Postgres 호환).
// String[] / Json 등 Postgres 전용 기능 사용. SQLite 미지원.
//
// 다음 단계:
//   1) `cp .env.local.example .env.local` → DATABASE_URL 채우기
//   2) `npx prisma migrate dev --name init` (Supabase Postgres로 마이그레이션)
//   3) `npx prisma db seed` (mock 데이터를 DB로 이관)
//   4) `npx prisma generate` (Prisma Client 코드 생성)
//   5) `npx prisma studio` (DB GUI로 확인)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  owner
  admin
  member
}

enum Gender {
  M
  F
}

enum ChildStatus {
  active
  leave
  left
}

enum Relation {
  부
  모
  조부모
  기타
}

enum AttendanceStatusChild {
  등원
  결석
  조퇴
  보건휴식
  미등원
}

enum AttendanceStatusStaff {
  출근
  결근
  휴가
  외출
  미체크
}

enum CareLogCategory {
  식사
  학습
  놀이
  관찰
  기타
}

enum ChildDocumentKind {
  iep
  photo
  report
  other
}

enum StaffStatus {
  active
  leave
  retired
}

enum VolunteerType {
  공익근무자
  자원봉사자
  실습생
  기타
}

// ─── Leave (휴가) ────────────────────────────────────────

/// 휴가 종류
enum LeaveType {
  ANNUAL             // 연차
  MATERNITY          // 출산휴가
  MATERNITY_MULTI    // 출산휴가-다태아
  SPOUSE_CARE        // 배우자돌봄휴가
  FAMILY_CARE        // 가족돌봄휴가
  REFRESH            // Refresh휴가 (3년 근속)
  EARLY_LEAVE        // 조퇴
  LATE_ARRIVAL       // 지각
  FAMILY_EVENT       // 경조사
  OFFICIAL           // 공가
  SICK               // 병가
  HALF_DAY           // 반차
}

/// 휴가 요청 상태
enum LeaveStatus {
  PENDING    // 대기
  APPROVED   // 승인
  REJECTED   // 반려
  CANCELLED  // 취소
  USED       // 사용완료
}

/// 휴가 요청
model LeaveRequest {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId     String
  staff       Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type        LeaveType
  startDate   String      // YYYY-MM-DD
  endDate     String      // YYYY-MM-DD
  days        Float       // 휴가 일수 (반차 0.5)
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId])
  @@index([staffId])
  @@index([startDate])
  @@index([status])
}

enum MemberStatus {
  active
  leave
}

enum DocKind {
  html
  hwp
}

/// 문서 분류 (P6 만료 추적용 — 결재/아동/직원/재정 등 평가단 점검 영역)
enum DocCategory {
  STAFF // 직원 — 4대 폭력/범죄경력/이수증
  CHILD // 아동 — IEP/사진/기타 첨부
  FINANCE // 재정 — 후원금/영수증/회계
  MEETING // 회의 — 운영위원회/총회
  PROGRAM // 프로그램 — 연간/월간 계획
  FACILITY // 시설 — 안전점검표/소화기 점검
}

enum DocumentKind {
  html_doc // /docs HTML 문서
  hwp_doc // /docs/hwp
  child_card // /children/[id] observations
  care_log // 돌봄일지
  child_document // 아동 첨부 (IEP 등)
  approval_doc // 결재함 진행 문서
}

enum ApprovalRequestStatus {
  결재중
  완료
  반려
  회수
}

enum ApprovalStepStatus {
  pending
  current
  approved
  rejected
}

enum ApprovalFormKey {
  education
  leave
  expense
  purchase
  report
  memo
  duty_assignment // 업무 분장표 (지역아동센터 핵심)
  meeting        // 회의록 (P10 연동)
  donation       // 후원금 영수증 (P8 연동)
}

enum AnnualPlanStatus {
  draft
  active
  done
}

enum MonthlyPlanStatus {
  draft
  active
  done
}

enum DailyLogStatus {
  draft
  pending
  approved
}

// ─── Inspection (디지털 안전점검) ───────────────────────

/// 디지털 안전점검 (소방/위생/5대 안전 교육 등)
model Inspection {
  id        String             @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  InspectionCategory
  title     String
  checkedAt DateTime          @default(now())
  checkedBy String?
  status    InspectionStatus  @default(PASSED)
  notes     String?
  items     InspectionItem[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, status])
}

/// 점검 항목 (체크리스트 한 행)
model InspectionItem {
  id           String           @id @default(cuid())
  inspectionId String
  inspection   Inspection       @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  label        String
  result       InspectionResult @default(PENDING)
  note         String?
  position     Int

  @@index([inspectionId])
}

enum InspectionCategory {
  FIRE_SAFETY  // 소방 안전
  HYGIENE      // 위생 점검
  EDUCATION    // 5대 안전 교육
  EMERGENCY    // 응급/피난
  ETC          // 기타
}

enum InspectionStatus {
  PASSED  // 합격
  FAILED  // 불합격
  PENDING // 대기
}

enum InspectionResult {
  PASS    // 적합
  FAIL    // 부적합
  NA      // 해당없음
  PENDING // 미확인
}

/// 후원 종류 — 금전(CASH) / 물품(GOODS)
enum DonationType {
  CASH
  GOODS
}

// ─── Meetings (P10 — 회의록 3종 + 운영위원회 결재 자동 트리거) ──────

/// 회의 종류 — 평가단 점검 영역
///   CHILD_COUNCIL: 아동자치회의 (월 1회 이상 권장)
///   GOVERNANCE:    운영위원회 (분기 1회 이상 — 결재 자동 트리거)
///   STAFF:         종사자회의 (월 1회 이상 권장)
enum MeetingType {
  CHILD_COUNCIL
  GOVERNANCE
  STAFF
}

/// 회의록 — 안건/본문/참석자/결정사항/첨부 문서 연결
/// GOVERNANCE 타입으로 저장 시 자동으로 ApprovalRequest 생성 (시설장 → 센터장 2-step)
model Meeting {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       MeetingType
  title      String
  /// 회의 일시 (DateTime — day + time)
  heldAt     DateTime
  location   String?
  /// 안건 목록
  agenda     String[]
  /// 본문 (마크다운/HTML)
  content    String?
  /// 참석자 이름 목록
  attendees  String[]
  /// 결석자 이름 목록
  absent     String[]
  /// 결정 사항 목록
  decisions  String[]
  /// 첨부 문서 id (Doc 모델 연결, 추후 HWP export)
  docId      String?
  /// GOVERNANCE 결재 시 자동 spawn된 ApprovalRequest id
  approvalId String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, heldAt])
  @@index([approvalId])
}

// ─── Tenant & Users ────────────────────────────────────

/// 멀티테넌트 루트 (양산애사희적합동조합 내 여러 아동센터)
model Tenant {
  id              String   @id @default(cuid())
  tenantCode      String   @unique  // 사이트 아이디 (e.g., 17000004442)
  siteName        String   // 사이트명 (e.g., 서창지역아동센터)
  defaultDomain   String   @unique  // 기본 도메인 (e.g., sc23.ourdomain.com)
  customDomain    String?  @unique  // 커스텀 도메인 (e.g., 55hsxpm6fe.co.co)
  plan            String   @default("basic")  // basic/pro/enterprise
  status          String   @default("active")  // active/suspended/deleted
  startDate       DateTime
  expireDate      DateTime?
  memberLimit     Int      @default(20)  // 회원 제한
  storageLimit    Int      @default(5368709120)  // 5GB 기본
  usedStorage     Int      @default(0)
  enabledApps     String   @default("dashboard,staff,children,approval,attendance")  // CSV
  theme           String?  // 테마 색상
  logoUrl         String?
  ownerEmail      String?  // 최고관리자 이메일
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users        User[]
  children     Child[]
  staff        Staff[]
  volunteers   Volunteer[]
  members      Member[]
  docs         Doc[]
  approvals    ApprovalRequest[]
  annualPlans  AnnualPlan[]
  dailyLogs    DailyLog[]
  inspections   Inspection[]
  donations     Donation[]
  meetings      Meeting[]
  leaveRequests LeaveRequest[]

  @@index([tenantCode])
  @@index([defaultDomain])
  @@map("tenants")
}

/// 종사자 · 조합원 · 자원봉사자 통합 유저
/// (현재는 mock — 실 인증은 Supabase Auth와 나중에 연결)
model User {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String   @unique
  name        String
  role        UserRole @default(member)
  loginId     String?
  position    String?
  department  String?
  avatarColor String   @default("slate")
  staff       Staff?   @relation("UserStaff")
  member      Member?  @relation("UserMember")
  createdAt   DateTime @default(now())
}

// ─── Children ──────────────────────────────────────────

/// 아동 메인 엔트리 (PDF 아동카드 + 자유 기술 등 8개 섹션 매핑)
model Child {
  id                    String      @id @default(cuid())
  tenantId              String
  tenant                Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// 전체 이름 — `${nameLast}${nameFirst}` 와 동일
  name                  String
  nameLast              String
  nameFirst             String
  birthDate             String // YYYY-MM-DD
  gender                Gender
  phone                 String?
  photoUrl              String?
  capacityGroup         Int // 30 / 40 / 50
  grade                 String?
  school                String?
  /// 보호자 (1:1 embed)
  guardianName          String
  guardianRelation      Relation
  guardianType          String?
  guardianPhone         String
  guardianJob           String?
  guardianNotes         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  /// 건강
  allergies             String[]
  medications           String[]
  healthNotes           String      @default("")
  enrolledAt            String // 입소일
  previousEnrolledAt    String? // 재입소 시 이전 기간
  leftAt                String? // 퇴소일
  address               String?
  serviceType           String?
  medianIncomePct       Int?
  kidsCallId            String?
  status                ChildStatus @default(active)
  /// 작성자 (child card writtenBy)
  authorId              String?
  authorName            String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  cardMeta     ChildCardMeta?
  physical     ChildPhysical?
  observations ChildObservations?
  attendances  Attendance[]
  careLogs     CareLog[]
  documents    ChildDocument[]

  @@index([tenantId])
  @@index([status])
}

/// 아동 카드 메타 (1:1)
model ChildCardMeta {
  childId          String  @id
  tenantId         String  @default("t-001")
  child            Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  number           String? // 예: AC-2026-001
  identityType     String?
  identityVerified String?
  referredBy       String?

  @@index([tenantId])
}

/// 신체 정보 (1:1)
model ChildPhysical {
  childId   String  @id
  tenantId  String  @default("t-001")
  child     Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  height    Float?
  weight    Float?
  buildType String?
  faceShape String?
  hairColor String?
  hairStyle String?

  @@index([tenantId])
}

/// 자유 기술 7개 섹션 (1:1)
model ChildObservations {
  childId     String  @id
  tenantId    String  @default("t-001")
  child       Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  personality String?
  family      String?
  healthObs   String?
  social      String?
  interests   String?
  learning    String?
  behavior    String?

  @@index([tenantId])
}

/// 일별 출석 (Child)
model Attendance {
  id        String                @id @default(cuid())
  tenantId  String                @default("t-001")
  childId   String
  child     Child                 @relation(fields: [childId], references: [id], onDelete: Cascade)
  date      String // YYYY-MM-DD
  status    AttendanceStatusChild
  note      String?
  authorId  String
  createdAt DateTime              @default(now())

  @@unique([childId, date])
  @@index([tenantId])
  @@index([date])
}

/// 돌봄일지
model CareLog {
  id         String          @id @default(cuid())
  tenantId   String          @default("t-001")
  childId    String
  child      Child           @relation(fields: [childId], references: [id], onDelete: Cascade)
  date       String
  category   CareLogCategory
  content    String
  authorId   String
  authorName String
  createdAt  DateTime        @default(now())

  @@index([tenantId])
  @@index([childId, date])
}

/// 아동 첨부 문서 (IEP, 사진 등)
model ChildDocument {
  id        String            @id @default(cuid())
  tenantId  String            @default("t-001")
  childId   String
  child     Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  filename  String
  /// 텍스트 or 파일 경로 (현재는 텍스트만)
  content   String
  kind      ChildDocumentKind
  authorId  String
  createdAt DateTime          @default(now())

  @@index([tenantId])
}

// ─── Staff ─────────────────────────────────────────────

model Staff {
  id       String      @id @default(cuid())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String?     @unique
  user     User?       @relation("UserStaff", fields: [userId], references: [id])
  name     String
  loginId  String
  gender   Gender
  phone    String
  position String
  joinDate String
  email    String?
  status   StaffStatus @default(active)

  attendances     StaffAttendance[]
  leaveRequests   LeaveRequest[]
  careers         StaffCareer[]
  certifications StaffCertification[]
  trainings       StaffTraining[]

  @@index([tenantId])
}

/// 직원 근태 (출퇴근 + 휴가/외출/미체크)
model StaffAttendance {
  id          String                @id @default(cuid())
  tenantId    String                @default("t-001")
  staffId     String
  staff       Staff                 @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date        String
  clockIn     String? // HH:mm
  clockOut    String? // HH:mm
  workMinutes Int?
  status      AttendanceStatusStaff
  note        String?
  authorId    String

  @@unique([staffId, date])
  @@index([tenantId])
  @@index([date])
}

// ─── Volunteers ────────────────────────────────────────

model Volunteer {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  gender       Gender
  phone        String
  type         VolunteerType
  startDate    String
  endDate      String?
  organization String?
  note         String?
  status       String        @default("active")

  attendances VolunteerAttendance[]

  @@index([tenantId])
}

/// 봉사자 등원/결석
model VolunteerAttendance {
  id          String    @id @default(cuid())
  tenantId    String    @default("t-001")
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  date        String
  present     Boolean
  reason      String?
  authorId    String

  @@unique([volunteerId, date])
  @@index([tenantId])
  @@index([date])
}

// ─── Members (조합원) ───────────────────────────────────

model Member {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String?      @unique
  user         User?        @relation("UserMember", fields: [userId], references: [id])
  name         String
  /// 개인 / 법인
  type         String       @default("개인")
  /// 출자금 (원)
  contribution Int          @default(0)
  joinDate     String
  status       MemberStatus @default(active)

  @@index([tenantId])
}

// ─── Documents (HTML/HWP) ──────────────────────────────

model Doc {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String
  content    String // HTML 또는 HWP 직렬화
  kind       DocKind
  authorId   String
  authorName String
  /// P6 — 만료일 (예: 4대 폭력 갱신일, 범죄경력 재발급, 이수증 유효기간)
  expiryDate DateTime?
  /// P6 — 문서 분류 (평가단 점검 영역별 분류)
  category   DocCategory?
  /// P6 — 원본 시스템 식별자 타입 (예: "child", "staff", "approval" — 향후 확장)
  sourceType String?
  /// P6 — 원본 시스템 ID (sourceType과 짝)
  sourceId   String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([tenantId])
  @@index([kind])
  @@index([expiryDate])
  @@index([category])
}

// ─── Document Index (통합 인덱스) ───────────────────────
//
// Write-through 방식으로 모든 문서성 데이터의 단일 인덱스.
// 목록/검색 페이지에서 이 테이블만 조회.

model DocumentIndex {
  id         String       @id
  tenantId   String
  kind       DocumentKind
  title      String
  snippet    String?
  sourceUrl  String
  childId    String?
  authorId   String
  authorName String
  meta       Json? // { form, docNo, status, category, fileType, ... }
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([tenantId, kind])
  @@index([childId])
  @@index([authorId])
}

// ─── Approval ──────────────────────────────────────────

model ApprovalRequest {
  id            String                @id @default(cuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentId    String // 원본 문서 id
  documentUrl   String
  documentKind  String // DocumentKind 와 동일 문자열 union
  title         String
  form          ApprovalFormKey
  requesterId   String
  requesterName String
  status        ApprovalRequestStatus @default(결재중)
  urgent        Boolean               @default(false)
  hasFile       Boolean               @default(false)
  docNo         String?               @unique
  snippet       String?
  createdAt     DateTime              @default(now())
  completedAt   DateTime?

  steps ApprovalStep[]

  @@index([tenantId, status])
  @@index([requesterId])
}

/// 결재선 단계
model ApprovalStep {
  id        String             @id @default(cuid())
  tenantId  String             @default("t-001")
  requestId String
  request   ApprovalRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  step      Int // 1..N
  name      String
  position  String
  status    ApprovalStepStatus @default(pending)
  actedAt   DateTime?
  comment   String?

  @@unique([requestId, step])
  @@index([tenantId])
}

// ─── 운영 계획 (Annual → Monthly → Daily) ──────────────

model AnnualPlan {
  id                     String           @id @default(cuid())
  tenantId               String
  tenant                 Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year                   Int
  title                  String
  status                 AnnualPlanStatus @default(draft)
  goals                  String[]
  evaluationScore        Int?
  evaluationSummary      String?
  evaluationHighlights   String[]
  evaluationImprovements String[]
  evaluatedBy            String?
  evaluatedAt            DateTime?
  createdBy              String
  createdAt              DateTime         @default(now())
  approvedBy             String?
  approvedAt             DateTime?

  programs     Program[]
  monthlyPlans MonthlyPlan[]

  @@unique([tenantId, year])
}

/// 연간 프로그램 (심리안정, 학습멘토링, 방과후교실 등)
model Program {
  id              String     @id @default(cuid())
  tenantId        String     @default("t-001")
  annualPlanId    String
  annualPlan      AnnualPlan @relation(fields: [annualPlanId], references: [id], onDelete: Cascade)
  name            String
  targetGroup     String
  weeklyFrequency Int
  method          String
  monthlyTargets  String[]
  materials       String[]

  @@index([tenantId])
}

model MonthlyPlan {
  id           String            @id @default(cuid())
  tenantId     String            @default("t-001")
  annualPlanId String
  annualPlan   AnnualPlan         @relation(fields: [annualPlanId], references: [id], onDelete: Cascade)
  year         Int
  /// 1..12
  month        Int
  status       MonthlyPlanStatus @default(draft)
  progressPct  Int?
  kpiAchieved  String[]
  notes        String?
  evaluatedBy  String?
  evaluatedAt  DateTime?

  weeklyGoals WeeklyGoal[]
  dailyLogs   DailyLog[]

  @@unique([annualPlanId, month])
  @@index([tenantId])
}

model WeeklyGoal {
  id            String      @id @default(cuid())
  tenantId      String      @default("t-001")
  monthlyPlanId String
  monthlyPlan   MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)
  /// 1..5
  weekNumber    Int
  goal          String
  activities    String[]

  @@unique([monthlyPlanId, weekNumber])
  @@index([tenantId])
}

/// 운영일지 — raw HTML content
model DailyLog {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthlyPlanId String?
  monthlyPlan   MonthlyPlan?   @relation(fields: [monthlyPlanId], references: [id])
  date          String
  title         String
  authorName    String
  authorRole    String
  status        DailyLogStatus @default(draft)
  /// Raw HTML — dangerouslySetInnerHTML 로 렌더
  content       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId, date])
  @@index([monthlyPlanId])
}

// ─── Budget (P13 — 회계 포털 예산) ────────────────────────

model Budget {
  id         String   @id @default(cuid())
  tenantId   String   @default("t-001")
  fiscalYear Int
  month      Int // 1~12
  category   String // 인건비/운영비/사업비/후원금/보조금
  limit      Int // 한도 (원)
  used       Int     @default(0)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([fiscalYear, month, category])
  @@index([tenantId])
  @@map("budgets")
}

// ─── Expense (P13 — 회계 포털 지출) ───────────────────────

model Expense {
  id         String   @id @default(cuid())
  tenantId   String   @default("t-001")
  approvalId String?
  fiscalYear Int
  month      Int
  date       DateTime
  category   String
  amount     Int
  vendor     String?
  memo       String?
  status     String  @default("확정")
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@map("expenses")
}

// ─── Donations (P8 — 후원금/물품 대장 + 영수증 매칭) ──────
//
// 재정 투명성 평가:
//   - 후원자/후원물품을 등록 + 영수증 발급
//   - 영수증 번호는 일련번호로 채번 — 추후 회계 검증 가능
//   - CASH: 금액(amount) / GOODS: 물품명(itemName) + 수량(itemQty) — 둘 다 있어도 무방

model Donation {
  id            String       @id @default(cuid())
  tenantId      String
  donorName     String
  /// 후원자 연락처 (선택)
  donorContact  String?
  type          DonationType
  /// CASH일 때 금액 (원)
  amount        Decimal?     @db.Decimal(12, 2)
  /// GOODS일 때 물품명
  itemName      String?
  /// GOODS일 때 수량
  itemQty       Int?
  receivedAt    DateTime     @default(now())
  /// 영수증 발급 여부 — 한 번 발급하면 회계 검증 사슬 유지
  receiptIssued Boolean      @default(false)
  /// 채번된 영수증 번호 (예: RC-2026-0001) — 발급 시에만 부여
  receiptNumber String?      @unique
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId, receivedAt])
  @@index([tenantId, type])
  @@index([receiptNumber])
}

// ─── Staff Extended (P15 — 경력/자격/교육) ───────────────

model StaffCareer {
  id          String   @id @default(cuid())
  tenantId    String   @default("t-001")
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime?
  orgName     String
  position    String?
  jobDesc     String?
  recognition String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([staffId])
  @@map("staff_careers")
}

model StaffCertification {
  id          String    @id @default(cuid())
  tenantId    String    @default("t-001")
  staffId     String
  staff       Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  certType    String
  certNo      String?
  issueDate   DateTime
  issuer      String?
  expiryDate  DateTime?
  recognition Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([staffId])
  @@map("staff_certifications")
}

model StaffTraining {
  id           String    @id @default(cuid())
  tenantId     String    @default("t-001")
  staffId      String
  staff        Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  trainingName String
  startDate    DateTime
  endDate      DateTime?
  hours        Int?
  institution  String?
  certUrl      String?
  type         String?
  createdAt    DateTime  @default(now())

  @@index([tenantId])
  @@index([staffId])
  @@map("staff_trainings")
}
